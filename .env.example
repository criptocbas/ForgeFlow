# ForgeFlow - Solana Blitz v5
# Public devnet endpoints are free for development. Use Magic Router for easiest routing.

# Base Solana (for delegation setup, commits, FlashTrade onchain reads)
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_WS=wss://api.devnet.solana.com

# MagicBlock Ephemeral Rollup / Router (recommended: router for automatic routing)
# See https://www.magicblock.xyz/blog/magic-router and docs
NEXT_PUBLIC_ER_ROUTER_RPC=https://devnet-router.magicblock.app
NEXT_PUBLIC_ER_ROUTER_WS=wss://devnet-router.magicblock.app

# Direct ER (fallback or explicit)
NEXT_PUBLIC_ER_RPC=https://devnet.magicblock.app
NEXT_PUBLIC_ER_WS=wss://devnet.magicblock.app

# Optional TEE / Private ER
# NEXT_PUBLIC_TEE_RPC=https://devnet-tee.magicblock.app

# Wallet / local dev
# ANCHOR_WALLET=~/.config/solana/id.json
# ANCHOR_PROVIDER_URL=https://api.devnet.solana.com

# FlashTrade (use their SDK + public endpoints / onchain program when possible)
# FLASH_TRADE_PROGRAM_ID=FLASH6Lo6h3iasJKWDs2F8TkW2UKf3s15C8PMGuVfgBn
# Any API keys if required by their services (check their docs)
